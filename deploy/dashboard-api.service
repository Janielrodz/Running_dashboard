[Unit]
Description=Running Dashboard API
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/running-dashboard/backend
ExecStart=/home/ubuntu/running-dashboard/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=DB_PATH=/home/ubuntu/HealthData/DBs/garmin_activities.db

[Install]
WantedBy=multi-user.target
